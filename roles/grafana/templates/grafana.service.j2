# This file is managed by Ansible. Manual changes will be overwritten.

[Unit]
Description=Grafana Dashboard Server
Documentation=https://grafana.com/docs/grafana/latest/
After=network-online.target
Wants=network-online.target

[Service]
User={{ grafana_user }}
Group={{ grafana_group }}
Type=simple
Restart=on-failure
RestartSec=5s
WorkingDirectory={{ grafana_install_dir }}
ExecStart={{ grafana_install_dir }}/bin/grafana server \
  --config={{ grafana_config_dir }}/grafana.ini \
  --homepath={{ grafana_install_dir }} \
  --pidfile=/var/run/grafana/grafana.pid
RuntimeDirectory=grafana
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
