# This file is managed by Ansible. Manual changes will be overwritten.

global:
  scrape_interval:     {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}
  external_labels:
    cluster: "{{ prometheus_cluster_name }}"
    replica: "{{ inventory_hostname }}"

alerting:
  alertmanagers:
{% for host in groups['alertmanager'] %}
    - static_configs:
        - targets:
            - "{{ hostvars[host]['ansible_host'] }}:{{ alertmanager_port }}"
{% endfor %}

rule_files:
  - "{{ prometheus_rules_dir }}/*.yml"

scrape_configs:

  # Prometheus self-monitoring
  - job_name: "prometheus"
    static_configs:
      - targets:
          - "localhost:{{ prometheus_port }}"

  # Node exporter on all monitoring hosts
  - job_name: "node_exporter"
    static_configs:
      - targets:
{% for host in groups['monitoring'] %}
          - "{{ hostvars[host]['ansible_host'] }}:{{ node_exporter_port }}"
{% endfor %}

  # Alertmanager self-monitoring
  - job_name: "alertmanager"
    static_configs:
      - targets:
{% for host in groups['alertmanager'] %}
          - "{{ hostvars[host]['ansible_host'] }}:{{ alertmanager_port }}"
{% endfor %}

  # Grafana self-monitoring
  - job_name: "grafana"
    static_configs:
      - targets:
{% for host in groups['grafana'] %}
          - "{{ hostvars[host]['ansible_host'] }}:{{ grafana_port }}"
{% endfor %}

  # Blackbox exporter self-monitoring
  - job_name: "blackbox_exporter"
    static_configs:
      - targets:
{% for host in groups['blackbox_exporter'] %}
          - "{{ hostvars[host]['ansible_host'] }}:{{ blackbox_exporter_port }}"
{% endfor %}

{% if prometheus_blackbox_http_targets %}
  # HTTP endpoint probing via blackbox_exporter
  - job_name: "blackbox_http"
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
{% for target in prometheus_blackbox_http_targets %}
          - "{{ target }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "{{ hostvars[groups['blackbox_exporter'][0]]['ansible_host'] }}:{{ blackbox_exporter_port }}"
{% endif %}

{% if prometheus_blackbox_tcp_targets %}
  # TCP port probing via blackbox_exporter
  - job_name: "blackbox_tcp"
    metrics_path: /probe
    params:
      module: [tcp_connect]
    static_configs:
      - targets:
{% for target in prometheus_blackbox_tcp_targets %}
          - "{{ target }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "{{ hostvars[groups['blackbox_exporter'][0]]['ansible_host'] }}:{{ blackbox_exporter_port }}"
{% endif %}

{% if prometheus_blackbox_icmp_targets %}
  # ICMP ping probing via blackbox_exporter
  - job_name: "blackbox_icmp"
    metrics_path: /probe
    params:
      module: [icmp]
    static_configs:
      - targets:
{% for target in prometheus_blackbox_icmp_targets %}
          - "{{ target }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "{{ hostvars[groups['blackbox_exporter'][0]]['ansible_host'] }}:{{ blackbox_exporter_port }}"
{% endif %}
