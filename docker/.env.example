# Path to the Go event-service directory (relative to docker/ or absolute)
# Default assumes event-service is a sibling of the Monitoring folder:
#   Projects/
#     DevOps/Monitoring/docker/   ← you are here
#     event-service/              ← Go project
EVENT_SERVICE_PATH=../../event-service

# MinIO credentials (used by both the MinIO container and Elasticsearch keystore)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
